# NBA Churn Retention Engine — Environment Variables
# Copy this to .env and fill in your values. Never commit .env to git.

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=nba-churn-retention-engine

# API
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# Dashboard — USD→INR display rate (dashboard shows all currency in ₹)
USD_TO_INR=83.0

# Data paths (override defaults)
# RAW_DATA_PATH=data/raw/saas_churn_dataset.csv
# PROCESSED_DATA_PATH=data/processed/engineered_features.csv

# Database (production data source — used with `make pipeline-db` / --source db)
# Option 1: a full SQLAlchemy URL (takes precedence over the parts below).
#   PostgreSQL: postgresql+psycopg2://user:pass@host:5432/dbname
#   SQLite (local testing): sqlite:///data/raw/churn.db
# DB_URL=postgresql+psycopg2://analytics_user:your_password@localhost:5432/saas_analytics

# Option 2: individual parts (assembled into a PostgreSQL URL).
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=saas_analytics
# DB_USER=analytics_user
# DB_PASSWORD=your_password_here

# Path to the .sql file run against the database (defaults to config/churn_query.sql).
# SQL_QUERY_PATH=config/churn_query.sql

# Notification (optional — Slack webhook for pipeline alerts)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/HERE
